# Browser-facing API prefix. Keep the default when using the Vite proxy.
VITE_API_BASE_URL=/api/v1

# Browser-facing live stream path. Vite proxies this to the backend in development.
VITE_WS_PATH=/ws/live-feed

# For deployments where the socket is hosted separately, set the complete ws:// or wss:// URL.
# VITE_WS_URL=wss://risk.example.com/ws/live-feed
