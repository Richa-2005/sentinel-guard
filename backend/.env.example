# Local development defaults to an Ollama server running on the host machine.
OLLAMA_BASE_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_SECONDS=60

# Local SQLite runtime state. Docker overrides this with /app/runtime.
SENTINEL_DATABASE_PATH=data/sentinel_storage.db

# Docker Desktop uses the Dockerfile default:
# OLLAMA_BASE_URL=http://host.docker.internal:11434/api/generate
